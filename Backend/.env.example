# Async SQLAlchemy PostgreSQL DSN using asyncpg.
DATABASE_URL=postgresql+asyncpg://voice_user:voice_password@localhost:5432/voice_assessment

# Supabase project API URL.
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key for server-side privileged operations.
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# AI report provider: anthropic or azure_openai.
AI_REPORT_PROVIDER=anthropic

# Anthropic API key for model calls.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Anthropic model used for assessment report generation.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Anthropic model used for low-cost live smoke checks.
ANTHROPIC_SMOKE_MODEL=claude-haiku-4-5-20251001

# Azure OpenAI endpoint used when AI_REPORT_PROVIDER=azure_openai.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Azure OpenAI API key used when AI_REPORT_PROVIDER=azure_openai.
AZURE_OPENAI_API_KEY=replace-with-azure-openai-api-key

# Azure OpenAI API version used when AI_REPORT_PROVIDER=azure_openai.
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure OpenAI chat deployment name used when AI_REPORT_PROVIDER=azure_openai.
AZURE_CHAT_DEPLOYMENT=replace-with-azure-chat-deployment

# Vapi API key for server-to-server Vapi requests.
VAPI_API_KEY=replace-with-vapi-api-key

# Vapi webhook HMAC secret used to validate inbound webhook signatures.
VAPI_WEBHOOK_SECRET=replace-with-vapi-webhook-secret

# Vapi REST API base URL.
VAPI_API_URL=https://api.vapi.ai

# Vapi call mode: web for browser voice sessions, phone for outbound PSTN calls.
VAPI_CALL_MODE=web

# Vapi phone number ID used only when VAPI_CALL_MODE=phone.
VAPI_PHONE_NUMBER_ID=

# Resend API key for transactional email.
RESEND_API_KEY=replace-with-resend-api-key

# Sender address used for report notification emails.
RESEND_FROM_EMAIL="Voice Assessment <reports@example.com>"

# Admin email address for critical operational alerts.
ADMIN_EMAIL=admin@example.com

# JWT signing secret for access tokens.
JWT_SECRET=replace-with-strong-random-jwt-secret

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Require email verification before login. Keep false for local/demo until verification emails are enabled.
REQUIRE_EMAIL_VERIFICATION=false

# Invite code required when a user signs up as assessor.
STAFF_SIGNUP_INVITE_CODE=

# Invite code required when a user signs up as admin.
ADMIN_SIGNUP_INVITE_CODE=

# Redis URL for JWT revocation. Leave blank for local demo mode.
REDIS_URL=

# Runtime environment: development, staging, or production.
ENVIRONMENT=development

# Application log level.
LOG_LEVEL=INFO

# JSON array of allowed browser origins for CORS.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
